packages:
  ./lore
  ./lore-tools
  ./lore-mcp
  ./lore-tools-cli

-- GHC 9.14 ships newer boot libraries than the current dependency bounds allow.
-- These selected dependency versions are verified to compile with that boot-library set.
allow-newer:
  *:base,
  *:bytestring,
  *:containers,
  *:deepseq,
  *:directory,
  *:filepath,
  *:ghc-bignum,
  *:ghc-prim,
  *:template-haskell,
  *:text,
  *:time,
  *:transformers,
  openapi3:hashable
